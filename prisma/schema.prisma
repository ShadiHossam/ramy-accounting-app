generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id          String   @id
  date        DateTime
  account     String   @db.VarChar(500)
  subAccount  String   @db.VarChar(500)
  analytical  String   @db.VarChar(500)
  costCenter  String   @db.VarChar(500)
  description String   @db.VarChar(1000)
  amount      Float
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([account])
}
